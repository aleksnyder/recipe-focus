{
  "manifest_version": 3,
  "name": "Recipe Focus",
  "version": "0.1",
  "description": "Recipe Filter shows recipes found anywhere on the web in a handy popup.",
  "icons": {
    "128": "img/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "recipe-focus@mozilla.org",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "background": {
    "scripts": ["js/background.js"]
  },
  "action": {
    "default_icon": "img/icon-128.png",
    "theme_icons": [{
      "light": "img/icon-128.png",
      "dark": "img/icon-128.png",
      "size": 128
    }],
    "default_title": "OFF"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+B",
        "mac": "Command+B"
      }
    }
  }
}